APP_NAME=ai-model
ENVIRONMENT=local
LOGGER_DEBUG=true
LOGGER_OUTPUT=stdout

DATABASE_URL=postgres://postgres:postgres@localhost:5432/autotest_ai?sslmode=disable
DATABASE_MIN_CONNS=1
DATABASE_MAX_CONNS=8

ALLURE_BASE_URL=https://allure.services.mts.ru
ALLURE_PROJECT_ID=271
ALLURE_USER_TOKEN=
ALLURE_BEARER_TOKEN=
ALLURE_PAGE_SIZE=200
ALLURE_SYNC_LAUNCH_LIMIT=20
ALLURE_LAUNCH_URL_TEMPLATE={base_url}/launch/{launch_id}
ALLURE_TEST_URL_TEMPLATE={base_url}/launch/{launch_id}/testresult/{test_result_id}

LLM_ENABLED=false
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4.1-mini
LLM_TIMEOUT=60s
LLM_TEMPERATURE=0.1

EMBEDDINGS_ENABLED=false
EMBEDDINGS_BASE_URL=https://api.openai.com/v1
EMBEDDINGS_API_KEY=
EMBEDDINGS_MODEL=text-embedding-3-small
EMBEDDINGS_TIMEOUT=30s

ANALYSIS_TOP_K_PER_QUERY=8
ANALYSIS_MAX_CANDIDATES=12
ANALYSIS_SCORE_THRESHOLD=0.55
ANALYSIS_HISTORY_WINDOW=20
ANALYSIS_STRONG_DEFECT_THRESHOLD=0.78
ANALYSIS_STRONG_RERUN_PASS_RATE=0.70
ANALYSIS_ATTACH_CANDIDATE_MINIMUM=0.70
ANALYSIS_TRANSIENT_PATTERN_BOOST=0.10
ANALYSIS_SEMANTIC_SEARCH_ENABLED=true
ANALYSIS_SEMANTIC_VIEW_NAME=knowledge_documents_embedding
